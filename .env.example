# ============================================
# VM Studio — Variables de Entorno
# Copiá este archivo a .env.local y completá
# los valores. NUNCA commitees .env.local.
# ============================================

# ── Base de Datos ──────────────────────────
MONGODB_URI=mongodb://localhost:27017/vmstudio

# ── JWT ────────────────────────────────────
JWT_SECRET=vm_studio_secret_key_2026_CAMBIA_ESTO
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer / Gmail SMTP) ────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=vmstudio.online@gmail.com
EMAIL_PASS=tu_app_password_de_gmail

# ── URLs ───────────────────────────────────
# En producción: https://vmstudioweb.online
CLIENT_URL=http://localhost:3000

# API pública (client-side fetch)
NEXT_PUBLIC_API_URL=/api

# ── Push Notifications (VAPID) ─────────────
# Generá tus propias keys con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:vmstudio.online@gmail.com
